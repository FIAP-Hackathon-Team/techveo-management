{
  "id": null,
  "uid": "techveo-containers",
  "title": "TechVeo - Containers",
  "tags": ["cadvisor", "techveo", "docker"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "title": "CPU Usage per Container (%)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rate(container_cpu_usage_seconds_total{image!=\"\",name=~\"techveo.*\"}[1m]) * 100",
          "legendFormat": "{{ name }}"
        }
      ]
    },
    {
      "id": 2,
      "title": "Memory Usage per Container (MB)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "container_memory_working_set_bytes{image!=\"\",name=~\"techveo.*\"} / 1024 / 1024",
          "legendFormat": "{{ name }}"
        }
      ]
    },
    {
      "id": 3,
      "title": "Network Receive (bytes/s)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rate(container_network_receive_bytes_total{name=~\"techveo.*\"}[1m])",
          "legendFormat": "{{ name }}"
        }
      ]
    },
    {
      "id": 4,
      "title": "Network Transmit (bytes/s)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rate(container_network_transmit_bytes_total{name=~\"techveo.*\"}[1m])",
          "legendFormat": "{{ name }}"
        }
      ]
    },
    {
      "id": 5,
      "title": "Disk I/O Read (bytes/s)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rate(container_fs_reads_bytes_total{name=~\"techveo.*\"}[1m])",
          "legendFormat": "{{ name }}"
        }
      ]
    },
    {
      "id": 6,
      "title": "Disk I/O Write (bytes/s)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rate(container_fs_writes_bytes_total{name=~\"techveo.*\"}[1m])",
          "legendFormat": "{{ name }}"
        }
      ]
    }
  ]
}
